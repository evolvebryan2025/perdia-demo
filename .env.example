# Production webhook - only used when explicitly specified
VITE_N8N_PUBLISH_WEBHOOK_PRODUCTION=https://your-n8n-instance/webhook/production-publish

# WordPress REST API (direct publishing)
# Application Password auth - generate at: wp-admin/profile.php#application-passwords
# Staging: API routes whitelisted via .htaccess, no site-level auth needed
VITE_WP_USERNAME=wwelsh
VITE_WP_APP_PASSWORD=your-application-password-here
